<!doctype html>
<html lang="ru">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{OG_TITLE}}</title>

  <!-- Open Graph snapshot, baked at creation time -->
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{TARGET}}">
  <meta property="og:title" content="{{OG_TITLE}}">
  <meta property="og:description" content="{{OG_DESCRIPTION}}">
  <meta property="og:image" content="{{OG_IMAGE}}">
  <meta property="og:site_name" content="{{OG_SITE_NAME}}">

  <!-- Twitter card mirror -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{OG_TITLE}}">
  <meta name="twitter:description" content="{{OG_DESCRIPTION}}">
  <meta name="twitter:image" content="{{OG_IMAGE}}">

  <!-- Bots get the meta and stop here. Humans continue via JS below.
       Fallback for no-JS humans: 2s meta-refresh. -->
  <meta http-equiv="refresh" content="2;url={{TARGET}}">

  <link rel="canonical" href="{{TARGET}}">

  {{METRIKA_BLOCK}}

  <style>
    :root {
      color-scheme: light dark;
      --fg: #1a1a1a;
      --bg: #fafafa;
      --muted: #6b7280;
      --accent: #2563eb;
    }
    @media (prefers-color-scheme: dark) {
      :root { --fg: #e5e7eb; --bg: #0f172a; --muted: #94a3b8; }
    }
    html, body { margin: 0; padding: 0; background: var(--bg); color: var(--fg); }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
      min-height: 100vh; display: grid; place-items: center;
      padding: 24px;
    }
    .card {
      max-width: 480px; text-align: center;
    }
    .label { font-size: 13px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted); margin-bottom: 12px; }
    .title { font-size: 22px; font-weight: 600; margin: 0 0 8px; }
    .desc { color: var(--muted); margin: 0 0 24px; }
    .target { word-break: break-all; color: var(--accent); text-decoration: none; font-size: 14px; }
    .target:hover { text-decoration: underline; }
    .hint { margin-top: 16px; font-size: 12px; color: var(--muted); }
  </style>
</head>
<body>
  <main class="card">
    <div class="label">Ярлыкон</div>
    <h1 class="title">{{OG_TITLE}}</h1>
    <p class="desc">{{OG_DESCRIPTION}}</p>
    <a class="target" href="{{TARGET}}" rel="noopener noreferrer">{{TARGET}}</a>
    <p class="hint">Перенаправление…</p>
  </main>

  <script>
    // UA-sniffing: known preview crawlers see only meta, no redirect.
    // They typically don't execute JS, so this is a belt-and-suspenders
    // measure (the <meta refresh> above also fires after 2s — bots ignore that).
    (function () {
      var ua = (navigator.userAgent || '').toLowerCase();
      var isBot = /telegrambot|vkshare|whatsapp|facebookexternalhit|twitterbot|slackbot|discordbot|linkedinbot|bingbot|googlebot|yandexbot/.test(ua);
      if (isBot) return;

      var target = {{TARGET_JSON}};

      function go() { location.replace(target); }

      // Дать Метрике шанс отстреляться (если она есть)
      if (typeof ym === 'function' && {{METRIKA_ID_JS}}) {
        try { ym({{METRIKA_ID_JS}}, 'hit', target); } catch (e) {}
        setTimeout(go, 150);
      } else {
        // Без Метрики редиректим сразу
        go();
      }
    })();
  </script>
</body>
</html>
